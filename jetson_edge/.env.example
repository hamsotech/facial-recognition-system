# ════════════════════════════════════════════════════════
# Jetson Edge Agent — .env.example
# Copy file này thành .env và điền giá trị thực
# ════════════════════════════════════════════════════════

# ── Địa chỉ FastAPI Server trên PC bạn ──────────────────
SERVER_URL=http://192.168.1.100:8000

# ── API Key (phải khớp với server) ──────────────────────
INTERNAL_API_KEY=your-secret-api-key-here

# ── Camera ───────────────────────────────────────────────
# 0 = CSI camera mặc định trên Jetson Orin
# hoặc đường dẫn RTSP: rtsp://admin:pass@192.168.1.x/stream1
CAMERA_INDEX=0

# ── AI Thresholds ─────────────────────────────────────────
SIMILARITY_THRESHOLD=0.65
SNAPSHOT_COOLDOWN=3.0
LIVENESS_MAD_THRESHOLD=1.4
LIVENESS_FRAME_COUNT=3
LIVENESS_FRAME_DELAY=0.12

# ── GPU Monitoring ────────────────────────────────────────
# Log GPU stats mỗi N giây (0 = tắt logging)
GPU_LOG_INTERVAL=30.0
# Cảnh báo khi nhiệt độ GPU vượt ngưỡng (°C)
GPU_WARN_TEMP_C=80.0

# ── Retry Queue ───────────────────────────────────────────
# Số tối đa payload chờ retry (tránh OOM)
RETRY_QUEUE_MAX=100
