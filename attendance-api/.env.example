# ══════════════════════════════════════════════════════════════════
# attendance-api/.env.example
# Copy file này thành .env và điền giá trị thực
# ══════════════════════════════════════════════════════════════════

# ── PostgreSQL Database ───────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=attendance_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# ── Spring Boot Backend ───────────────────────────────────────────
SPRING_URL=http://localhost:8080
SPRINGBOOT_INTERNAL_KEY=your-internal-api-key

# ── Camera ────────────────────────────────────────────────────────
# 0 = webcam mặc định | RTSP: rtsp://admin:pass@192.168.x.x/stream
CAMERA_INDEX=0

# ── Ngưỡng nhận diện (Similarity Threshold) ──────────────────────
# Mỗi model có ngưỡng tối ưu khác nhau (dựa trên benchmark)
FACENET_THRESHOLD=0.65
ARCFACE_THRESHOLD=0.50
MOBILEFACENET_THRESHOLD=0.55
DLIB_THRESHOLD=0.65

# ── Cài đặt chung cho tất cả pipeline ────────────────────────────
SNAPSHOT_COOLDOWN=3.0

# ── YOLO Model ────────────────────────────────────────────────────
YOLO_MODEL_PATH=yolov8n.pt